rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isHealthcareWorker() {
      return isAuthenticated() && request.auth.token.role in ['doctor', 'assistant'];
    }

    // Medical documents — healthcare workers only
    match /documents/{patientId}/{fileName} {
      allow read: if isHealthcareWorker();
      allow write: if isHealthcareWorker() &&
        request.resource.size < 25 * 1024 * 1024 && // 25MB limit
        request.resource.contentType.matches('application/(pdf|msword|octet-stream)');
      allow delete: if false;
    }

    // Audio files — written by functions only, read by healthcare workers
    match /audio/{allPaths=**} {
      allow read: if isHealthcareWorker();
      allow write: if false; // Functions write via Admin SDK
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
